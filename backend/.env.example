# PostgreSQL (Prisma)
# Supabase: DATABASE_URL = pooler (Session mode, port 6543) for the app; DIRECT_URL = direct Postgres (port 5432).
# Prisma uses DIRECT_URL for migrations/db push — wrong or missing DIRECT_URL can leave columns missing while `db push` reports "in sync".
DATABASE_URL=
DIRECT_URL=

# JWT (must match auth/verify-otp signing)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Upstash Redis — matching queues (REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bull queue (CloakScore jobs) — standard Redis TCP URL (not Upstash REST). Optional: jobs run in-process via setImmediate.
# REDIS_URL=redis://127.0.0.1:6379
# BULL_REDIS_URL=redis://127.0.0.1:6379

# Optional
PORT=4000
# Extra allowed browser origins (comma-separated), e.g. production URL. Local dev: any http(s)://localhost,
# 127.0.0.1, or ::1 with any port (5173, 5174, …) is always allowed — you do not need to list them.
# CLIENT_ORIGIN=https://your-production-app.example

# Comma-separated test Gmail(s) — bypass .ac.in format; default includes two accounts for two-tab video chat.
# WHITELIST_TEST_EMAILS=moorritik@gmail.com,moorritik6@gmail.com
# Legacy single-email override:
# WHITELIST_TEST_EMAIL=moorritik@gmail.com

# Where OTP is sent for normal college emails when Resend is in dev mode (not used for whitelisted test emails).
# RESEND_TEST_TO_EMAIL=moorritik@gmail.com

# Support / appeals (referenced in automated moderation emails)
# CLOAK_SUPPORT_EMAIL=support@yourdomain.com

# Razorpay — session extension (₹20), queue unlock (₹20), and CLOAK wallet top-up. Mock mode for dev.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# EXTENSION_PAYMENT_MOCK=true
