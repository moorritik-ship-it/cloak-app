# Leave empty to use Vite dev server proxy (see vite.config.js → http://localhost:4000).
# Only set this if you call the API without the proxy (then use full URL, e.g. http://localhost:4000).
# VITE_API_BASE_URL=

# Shown in-app for ban/appeal messaging (should match backend CLOAK_SUPPORT_EMAIL)
# VITE_CLOAK_SUPPORT_EMAIL=support@yourdomain.com
